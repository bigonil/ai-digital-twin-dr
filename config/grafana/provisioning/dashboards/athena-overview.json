{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "ATHENA Digital Twin DR — Observability Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Simulation Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max", "p95"], "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(athena_simulation_latency_seconds_bucket[5m])) by (le, origin_node_type))",
          "legendFormat": "p50 — {{origin_node_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(athena_simulation_latency_seconds_bucket[5m])) by (le, origin_node_type))",
          "legendFormat": "p95 — {{origin_node_type}}",
          "refId": "B"
        }
      ],
      "title": "Simulation Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(athena_affected_nodes_per_simulation_bucket[5m])) by (le))",
          "legendFormat": "p50 affected nodes",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(athena_affected_nodes_per_simulation_bucket[5m])) by (le))",
          "legendFormat": "p95 affected nodes",
          "refId": "B"
        }
      ],
      "title": "Affected Nodes per Simulation",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Database Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max", "p95"], "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(athena_neo4j_query_duration_seconds_bucket[5m])) by (le, query_type))",
          "legendFormat": "p50 — {{query_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(athena_neo4j_query_duration_seconds_bucket[5m])) by (le, query_type))",
          "legendFormat": "p95 — {{query_type}}",
          "refId": "B"
        }
      ],
      "title": "Neo4j Query Duration (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "rate(athena_simulation_cache_hits_total{result=\"hit\"}[5m]) / (rate(athena_simulation_cache_hits_total{result=\"hit\"}[5m]) + rate(athena_simulation_cache_hits_total{result=\"miss\"}[5m]))",
          "legendFormat": "Cache Hit Rate",
          "refId": "A"
        }
      ],
      "title": "Simulation Cache Hit Rate",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "HTTP Traffic (prometheus-fastapi-instrumentator)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (handler, method)",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p95 — {{handler}}",
          "refId": "A"
        }
      ],
      "title": "HTTP p95 Latency by Endpoint",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["athena", "dr", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ATHENA — DR Observability",
  "uid": "athena-overview",
  "version": 1
